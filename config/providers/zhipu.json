{
  "id": "zhipu",
  "name": "智谱 GLM",
  "enabled": true,
  "endpoint": {
    "protocol": "openai-chat-completions",
    "baseUrl": "https://open.bigmodel.cn/api/paas/v4/chat/completions"
  },
  "model": "glm-5.2",
  "credentials": {
    "envKeys": ["ZAI_API_KEY", "ZHIPU_API_KEY"]
  },
  "capabilities": {
    "reasoning": true,
    "code": true,
    "longContext": true,
    "streaming": true,
    "contextCache": true
  },
  "limits": {
    "contextChars": 24000,
    "timeoutMs": 45000,
    "outputTokens": {
      "compact": 768,
      "normal": 2048,
      "detailed": 4096,
      "minimum": 768,
      "maximum": 4096
    }
  },
  "routing": {
    "aliases": ["智谱", "GLM"],
    "keywords": ["翻译", "总结", "解释", "摘要", "润色"],
    "priority": 10
  }
}
