{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex/provider.schema.json",
  "title": "External LLM Provider",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "endpoint", "model", "credentials", "capabilities", "limits", "routing"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-zA-Z0-9_-]+$" },
    "name": { "type": "string", "minLength": 1 },
    "enabled": { "type": "boolean", "default": true },
    "endpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocol", "baseUrl"],
      "properties": {
        "protocol": { "enum": ["openai-chat-completions"] },
        "baseUrl": { "type": "string", "format": "uri" }
      }
    },
    "model": { "type": "string", "minLength": 1 },
    "modelProfiles": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "request": { "$ref": "#/$defs/request" },
          "capabilities": { "type": "object", "additionalProperties": { "type": "boolean" } },
          "limits": { "$ref": "#/$defs/limitsOverride" }
        }
      }
    },
    "credentials": {
      "type": "object",
      "additionalProperties": false,
      "required": ["envKeys"],
      "properties": {
        "envKeys": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" } }
      }
    },
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "properties": { "header": { "type": "string" }, "prefix": { "type": "string" } }
    },
    "headers": { "type": "object", "additionalProperties": { "type": "string" } },
    "request": { "$ref": "#/$defs/request" },
    "capabilities": { "type": "object", "additionalProperties": { "type": "boolean" } },
    "limits": { "$ref": "#/$defs/limits" },
    "routing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["aliases", "keywords", "priority"],
      "properties": {
        "aliases": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "keywords": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "priority": { "type": "integer", "minimum": 1 }
      }
    }
  },
  "$defs": {
    "request": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxOutputTokensField": { "type": "string", "minLength": 1 },
        "extraBody": { "type": "object" },
        "omitParameters": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contextChars", "timeoutMs", "outputTokens"],
      "properties": {
        "contextChars": { "type": "integer", "minimum": 1 },
        "timeoutMs": { "type": "integer", "minimum": 1 },
        "outputTokens": {
          "type": "object",
          "additionalProperties": false,
          "required": ["compact", "normal", "detailed", "minimum", "maximum"],
          "properties": {
            "compact": { "type": "integer", "minimum": 1 },
            "normal": { "type": "integer", "minimum": 1 },
            "detailed": { "type": "integer", "minimum": 1 },
            "minimum": { "type": "integer", "minimum": 1 },
            "maximum": { "type": "integer", "minimum": 1 }
          }
        }
      }
    },
    "limitsOverride": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "contextChars": { "type": "integer", "minimum": 1 },
        "timeoutMs": { "type": "integer", "minimum": 1 },
        "outputTokens": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "compact": { "type": "integer", "minimum": 1 },
            "normal": { "type": "integer", "minimum": 1 },
            "detailed": { "type": "integer", "minimum": 1 },
            "minimum": { "type": "integer", "minimum": 1 },
            "maximum": { "type": "integer", "minimum": 1 }
          }
        }
      }
    }
  }
}
